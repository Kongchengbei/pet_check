# ============================================
# 宠标通 · PetFeedCheck 后端环境变量
# 复制此文件为 .env 并填入真实值
# ============================================

# OCR Token — 百度 AIStudio
OCR_TOKEN=your_baidu_aistudio_token_here

# LLM Token — SiliconFlow API Key
LLM_TOKEN=sk-your-siliconflow-api-key-here

# 服务器配置
PORT=80
DEBUG=false

# LLM 调用配置
LLM_CONNECT_TIMEOUT=15
LLM_READ_TIMEOUT=180
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_SECONDS=2

# 默认 Qwen3 模型
QWEN3_NEXT_MODEL=Qwen/Qwen3-VL-30B-A3B-Thinking

# 临时文件目录
UPLOAD_FOLDER=./temp_images
