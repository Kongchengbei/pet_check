  justify-content: center;
  padding: 0 14rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  font-weight: 700;
  border: 2rpx solid rgba(255, 250, 241, 0.98);
  box-shadow: 0 5rpx 0 #bca084, 0 8rpx 12rpx rgba(63, 44, 30, 0.14);
}

.ac-error-btn.cancel {
  background: linear-gradient(180deg, #fff7fb 0%, #f5e9f4 100%);
  color: #7c5d6a;
}

.ac-error-btn.confirm {
  background: linear-gradient(180deg, #9ad6c0 0%, #67b48f 100%);
  color: #fffef8;
  box-shadow: 0 6rpx 0 #4e9473, 0 10rpx 14rpx rgba(52, 103, 79, 0.22);
}

.ac-toast-wrap {
  top: calc(env(safe-area-inset-top) + 120rpx);
}

.ac-toast {
  max-width: 640rpx;
  min-height: 88rpx;
  padding: 14rpx 20rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, #fff8fb 0%, #fff3e8 100%);
  border-color: rgba(255, 250, 241, 0.98);
  box-shadow: 0 6rpx 0 #d9b699, 0 12rpx 18rpx rgba(87, 59, 37, 0.18);
}

.ac-toast-icon {
  width: 42rpx;
  height: 42rpx;
  margin-right: 14rpx;
  border-radius: 14rpx;
  box-shadow: 0 4rpx 0 rgba(90, 90, 90, 0.16);
}

.ac-toast-text {
  font-size: 25rpx;
  color: #6b4d3f;
  word-break: break-all;
}

.md-alert {
  background: linear-gradient(180deg, #fffaf8 0%, #fff4ea 100%) !important;
  border-radius: 26rpx !important;
}

/* Final alignment pass */
.ac-panel-head {
  min-height: 118rpx;
  padding: 22rpx 26rpx;
}

.ac-panel-title-box {
  justify-content: center;
}

.ac-panel-title {
  font-size: 34rpx;
  line-height: 1.12;
}

.ac-panel-subtitle {
  font-size: 24rpx;
  line-height: 1.25;
  margin-top: 6rpx;
}

.ac-panel-icon-model {
  width: 82rpx;
  height: 82rpx;
  margin-right: 18rpx;
  padding: 0;
  overflow: hidden;
}

.ac-panel-icon-model-image {
  width: 100%;
  height: 100%;
  display: block;
  transform: scale(2.2) translateY(4rpx);
  transform-origin: center center;
}

.ac-quick-card .quick-options {
  gap: 12rpx !important;
}

.ac-quick-card .quick-option {
  display: grid !important;
  grid-template-columns: 46rpx minmax(0, 1fr) 34rpx;
  align-items: center !important;
  column-gap: 10rpx;
  min-height: 112rpx;
  padding: 16rpx 14rpx !important;
  justify-content: initial;
}

.ac-quick-card .quick-logo-wrapper {
  width: 48rpx;
  height: 48rpx;
}

.ac-quick-card .quick-name {
  display: block !important;
  flex: initial;
  width: 100%;
  min-width: 0;
  height: 46rpx;
  line-height: 46rpx;
  white-space: nowrap !important;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 25rpx;
  letter-spacing: 0;
  text-align: center;
}

.ac-quick-card .quick-check {
  position: static !important;
  top: auto;
  right: auto;
  transform: none;
  margin-left: 0 !important;
  width: 34rpx;
  height: 34rpx;
}

.ac-panel-icon-shell-photo {
  padding: 0;
  overflow: hidden;
}

.ac-panel-head-image {
  width: 100%;
  height: 100%;
  display: block;
}

.ac-panel-icon-shell-quick {
  padding: 0;
  overflow: hidden;
  background: linear-gradient(180deg, #fff8ef 0%, #f5efe1 100%);
}

.ac-panel-head-image-quick {
  transform: scale(1.16) translateY(0rpx);
  transform-origin: center center;
}

.ac-panel-icon-shell-result {
  background: linear-gradient(180deg, #fff7fb 0%, #f7edf5 100%);
}

.ac-panel-head-image-result {
  transform: scale(1.24) translateY(2rpx);
  transform-origin: center center;
}

/* Ensure the model picker stays as a fixed centered popup instead of the old bottom sheet */
.picker-mask {
  position: fixed !important;
  z-index: 1080 !important;
}

.picker-popup.ac-organic-popup {
  position: fixed !important;
  z-index: 1090 !important;
}

/* Restore inline model dropdown layout */
.ac-panel-right {
  padding-left: 16rpx;
}

.ac-panel-arrow {
  font-size: 26rpx;
}

.model-dropdown {
  margin-top: 4rpx;
  margin-bottom: 6rpx;
  padding: 12rpx;
  border-radius: 30rpx;
  background: rgba(250, 244, 232, 0.82);
  border: 2rpx solid rgba(255, 248, 234, 0.92);
  box-shadow: inset 0 -4rpx 0 rgba(179, 157, 126, 0.24);
}

.model-dropdown-item {
  min-height: 112rpx;
  padding: 18rpx 18rpx 18rpx 20rpx;
  margin-bottom: 14rpx;
  border-radius: 999rpx;
  background: #fbf7ef;
  border: 2rpx solid rgba(255, 249, 238, 0.95);
  box-shadow: 0 5rpx 0 rgba(182, 161, 130, 0.72), 0 10rpx 14rpx rgba(63, 44, 30, 0.08);
}

.model-dropdown-item:last-child {
  margin-bottom: 0;
}

.model-dropdown-item.selected {
  background: #fff4da;
  border-color: #f1e2b5;
}

.model-dropdown-item .model-logo-wrapper {
  width: 74rpx;
  height: 74rpx;
  margin-right: 18rpx;
}

.model-dropdown-item .model-name {
  font-size: 29rpx;
}

.model-dropdown-item .model-hint {
  max-width: none;
}

.model-dropdown-item .option-check {
  width: 50rpx;
  height: 50rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
  border-color: #d8c9a6;
  background: #f6eedc;
  color: transparent;
  box-shadow: inset 0 -3rpx 0 rgba(187, 161, 124, 0.28);
}

.model-dropdown-item .option-check.selected {
  background: linear-gradient(180deg, #76bf96 0%, #5aaa7c 100%) !important;
  border-color: #5b9875;
  color: #fffdf6;
  box-shadow: 0 4rpx 0 rgba(66, 134, 97, 0.78), 0 8rpx 12rpx rgba(53, 92, 69, 0.16);
}

.model-dropdown-item .option-check text {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  color: inherit;
}

.ac-quick-card .quick-check text {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  color: inherit;
}

/* Restore creamy prompt-card modal style */
.ac-delete-mask {
  background: rgba(48, 39, 30, 0.34);
}

.ac-delete-modal {
  left: 52rpx;
  right: 52rpx;
}

.ac-delete-ear {
  top: -8rpx;
  width: 56rpx;
  height: 28rpx;
  background: #fff8ee;
  border: none;
  box-shadow: 0 6rpx 12rpx rgba(81, 61, 43, 0.1);
}

.ac-delete-ear.left {
  left: 44rpx;
  transform: rotate(-34deg);
  border-radius: 16rpx 16rpx 0 0;
}

.ac-delete-ear.right {
  right: 44rpx;
  transform: rotate(34deg);
  border-radius: 16rpx 16rpx 0 0;
}

.ac-delete-body {
  background: linear-gradient(180deg, #fffaf2 0%, #fff4e9 100%) !important;
  border-radius: 34rpx;
  padding-top: 34rpx;
}

.ac-delete-title {
  font-size: 52rpx;
  margin-bottom: 16rpx;
}

.ac-delete-desc {
  font-size: 30rpx;
  margin: 0 34rpx 24rpx;
}

.ac-delete-actions {
  gap: 14rpx;
  padding: 18rpx 20rpx 22rpx;
}

.ac-delete-btn {
  height: 94rpx;
  border-radius: 30rpx !important;
  font-size: 32rpx;
}

.ac-delete-btn.cancel {
  background: linear-gradient(180deg, #fffbf2 0%, #f7f1e2 100%);
}

.ac-delete-btn.danger {
  background: linear-gradient(180deg, #ef9185 0%, #da5d53 100%);
}

/* Reduce tap flicker on large interactive blocks */
.upload-area,
.grid-item,
.action-btn,
.current-model,
.quick-option,
.submit-btn,
.copy-btn,
.share-btn,
.ac-delete-btn,
.model-dropdown-item {
  transition-property: background-color, border-color, box-shadow, opacity;
  transition-duration: 0.18s;
  transition-timing-function: ease;
  -webkit-tap-highlight-color: transparent;
}

.upload-area:active,
.grid-item:active,
.action-btn:active,
.current-model:active,
.quick-option:active,
.submit-btn:active,
.copy-btn:active,
.share-btn:active,
.ac-delete-btn:active,
.model-dropdown-item:active {
  transform: none !important;
  opacity: 0.96;
}

.upload-area:active {
  box-shadow: none !important;
}

.action-btn:active {
  box-shadow: inset 2rpx 2rpx 6rpx rgba(153, 162, 176, 0.14), inset -2rpx -2rpx 6rpx rgba(255, 255, 255, 0.75) !important;
}

.current-model:active,
.quick-option:active,
.submit-btn:active,
.copy-btn:active,
.share-btn:active {
  box-shadow: 0 6rpx 0 #b7a388, 0 10rpx 16rpx rgba(63, 44, 30, 0.16) !important;
}

.ac-delete-btn.cancel:active {
  box-shadow: 0 5rpx 0 #b7a388, 0 8rpx 12rpx rgba(63, 44, 30, 0.14) !important;
}

.ac-delete-btn.danger:active {
  box-shadow: 0 6rpx 0 #b84a40, 0 10rpx 14rpx rgba(100, 39, 33, 0.2) !important;
}
