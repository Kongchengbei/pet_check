page {
  height: 100vh;
  background: #FFFBEB;
  --primary-color: #F59E0B;
  --primary-dark: #D97706;
  --primary-light: #FEF3C7;
  --success-color: #10B981;
  --danger-color: #EF4444;
  --purple-color: #8B5CF6;
  --warning-color: #F59E0B;
  --info-color: #F59E0B;
}

.page-container {
  min-height: 100vh;
  position: relative;
}

.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: linear-gradient(135deg, #B45309 0%, #D97706 50%, #F59E0B 100%);
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 30rpx;
}

.navbar-logo {
  width: 56rpx;
  height: 56rpx;
  margin-right: 16rpx;
  border-radius: 14rpx;
  background: rgba(255,255,255,0.2);
  flex-shrink: 0;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 3rpx;
}

.container {
  height: calc(100vh - var(--nav-height, 88px));
  padding: 24rpx;
  box-sizing: border-box;
}

.header-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  overflow: hidden;
  pointer-events: none;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(245,158,11,0.1) 0%, rgba(245,158,11,0.05) 100%);
}

.c1 {
  width: 200rpx;
  height: 200rpx;
  top: -60rpx;
  right: -40rpx;
}

.c2 {
  width: 150rpx;
  height: 150rpx;
  top: 80rpx;
  right: 100rpx;
}

.c3 {
  width: 100rpx;
  height: 100rpx;
  top: 40rpx;
  left: 30rpx;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
}

.section-icon-box.blue {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.section-icon-box.green {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.section-icon-box.purple {
  background: linear-gradient(135deg, #EDE7F6 0%, #D1C4E9 100%);
}

.section-icon {
  font-size: 36rpx;
}

.section-title-box {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 4rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #8E99A4;
}

.upload-area {
  width: 100%;
  height: 380rpx;
  border: 3rpx dashed #D0D7DE;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  overflow: hidden;
  background: linear-gradient(145deg, #FAFBFC 0%, #F0F4F8 100%);
  transition: all 0.3s ease;
}

.upload-area:active {
  transform: scale(0.98);
  border-color: var(--primary-color);
}

.upload-container.single-mode {
  position: relative;
  width: 100%;
  height: 380rpx;
}

.image-wrapper {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.image-grid {
  display: grid;
  gap: 16rpx;
  width: 100%;
  height: 380rpx;
  position: relative;
}

.image-grid.grid-2 {
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: repeat(2, 1fr);
}

.image-grid.grid-2 .grid-item {
  height: 100%;
  padding-bottom: 0;
}

.image-grid.grid-3 {
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(3, 1fr);
}

.image-grid.grid-3 .grid-item {
  height: 100%;
  padding-bottom: 0;
}

.grid-item {
  position: relative;
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
  transition: all 0.3s ease;
}

.grid-item:active {
  transform: scale(0.98);
}

.grid-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.grid-item.moving {
  opacity: 0.3;
  transform: scale(0.9);
}

.grid-item.drag-over {
  border: 3rpx dashed var(--primary-color);
  background: rgba(66, 165, 245, 0.1);
}

.drag-ghost {
  position: fixed;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  z-index: 9999;
  pointer-events: none;
  transform: translate(-50%, -50%) scale(1.1);
  transition: none;
}

.drag-ghost-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-icon {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(239, 83, 80, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(239, 83, 80, 0.4);
  z-index: 10;
}

.add-item {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border: 3rpx dashed var(--primary-color);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  position: relative;
}

.add-item:active {
  background: linear-gradient(135deg, #FDE68A 0%, #FCD34D 100%);
}

.add-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 56rpx;
  color: var(--primary-color);
  font-weight: 300;
  line-height: 1;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.upload-icon-inner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.35);
}

.upload-icon-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: 4rpx solid rgba(245, 158, 11, 0.2);
  border-radius: 50%;
  animation: ring-pulse 2s infinite;
}

@keyframes ring-pulse {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  100% {
    transform: scale(1.2);
    opacity: 0;
  }
}

.upload-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
}

.upload-text {
  font-size: 28rpx;
  color: #3D5A80;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #8E99A4;
}

.image-actions {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  right: 16rpx;
  display: flex;
  gap: 12rpx;
  z-index: 20;
}

.image-actions.top-actions {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  right: 16rpx;
}

.action-btn {
  flex: 1;
  height: 56rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  white-space: nowrap;
  padding: 0 20rpx;
  min-width: 0;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  pointer-events: auto;
}


.change-btn {
  color: #1E88E5;
  border: 2rpx solid rgba(30, 136, 229, 0.5);
  background: rgba(30, 136, 229, 0.2);
}

.change-btn:active {
  background: rgba(30, 136, 229, 0.4);
  transform: scale(0.95);
}

.remove-btn {
  color: #E53935;
  border: 2rpx solid rgba(229, 57, 53, 0.5);
  background: rgba(229, 57, 53, 0.2);
}

.remove-btn:active {
  background: rgba(229, 57, 53, 0.4);
  transform: scale(0.95);
}

.add-btn {
  color: #4CAF50;
  border: 2rpx solid rgba(76, 175, 80, 0.5);
  background: rgba(76, 175, 80, 0.2);
}

.add-btn:active {
  background: rgba(76, 175, 80, 0.4);
  transform: scale(0.95);
}

.model-logo,
.quick-logo,
.option-logo,
.result-logo {
  width: 100%;
  height: 100%;
  border-radius: inherit;
}

.current-model {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #EEF2F7 100%);
  border-radius: 20rpx;
  border: 2rpx solid #E3E8EF;
  margin-bottom: 24rpx;
}

.current-model:active {
  background: linear-gradient(135deg, #EEF2F7 0%, #E3E8EF 100%);
  border-color: var(--primary-color);
}

.model-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.model-logo-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.model-detail {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
}

.model-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.model-hint {
  font-size: 22rpx;
  color: #8E99A4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 350rpx;
}

.model-arrow {
  width: 48rpx;
  height: 48rpx;
  background: #E3E8EF;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 20rpx;
  color: #8E99A4;
}

.quick-select {
  background: #FAFBFC;
  border-radius: 20rpx;
  padding: 20rpx;
}

.quick-header {
  margin-bottom: 16rpx;
}

.quick-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #5A6978;
}

.quick-options {
  display: flex;
  gap: 16rpx;
}

.quick-option {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 2rpx solid #E8ECF0;
  transition: all 0.25s ease;
  position: relative;
}

.quick-option.active {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-color: var(--primary-color);
}

.quick-option:active {
  transform: scale(0.96);
}

.quick-logo-wrapper {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.quick-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #3D5A80;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.quick-option.active .quick-name {
  color: var(--primary-dark);
}

.quick-check {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20rpx;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.4);
}

.button-section {
  padding: 16rpx 8rpx;
}

.submit-btn {
  width: 100% !important;
  height: 108rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 54rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none !important;
  box-shadow: 0 12rpx 40rpx rgba(245, 158, 11, 0.4);
  position: relative;
  overflow: hidden;
  padding: 0 !important;
  margin: 0 !important;
}

.submit-btn::after {
  border: none !important;
}

.submit-btn[disabled] {
  background: linear-gradient(135deg, #FCD34D 0%, #FBBF24 100%);
  box-shadow: 0 6rpx 20rpx rgba(245, 158, 11, 0.2);
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.btn-icon {
  font-size: 38rpx;
  margin-right: 12rpx;
}

.btn-text {
  letter-spacing: 6rpx;
}

.btn-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: shine 3s infinite;
}

@keyframes shine {
  0% {
    left: -100%;
  }
  50%, 100% {
    left: 150%;
  }
}

.submit-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 6rpx 20rpx rgba(245, 158, 11, 0.35);
}

.result-section {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  animation: slideUp 0.5s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  color: #fff;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
}

.result-model {
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.result-content {
  padding: 32rpx;
}

.md-h1 {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin: 32rpx 0 24rpx 0;
  padding-bottom: 16rpx;
  border-bottom: 3rpx solid #F59E0B;
}

.md-h2 {
  font-size: 34rpx;
  font-weight: 600;
  color: #2d3748;
  margin: 28rpx 0 20rpx 0;
  padding-left: 16rpx;
  border-left: 6rpx solid #F59E0B;
}

.md-h3 {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a5568;
  margin: 24rpx 0 16rpx 0;
}

.md-h4 {
  font-size: 28rpx;
  font-weight: 500;
  color: #718096;
  margin: 20rpx 0 12rpx 0;
}

.md-hr {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
  margin: 32rpx 0;
}

.md-paragraph {
  font-size: 28rpx;
  color: #4a5568;
  line-height: 1.8;
  margin: 16rpx 0;
}

.md-bold-paragraph {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d3748;
  margin: 20rpx 0;
  line-height: 1.6;
}

.md-list-item,
.md-ordered-item {
  display: flex;
  align-items: flex-start;
  margin: 12rpx 0;
  padding-left: 8rpx;
}

.md-bullet {
  color: #F59E0B;
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.md-order {
  color: #F59E0B;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 12rpx;
  min-width: 40rpx;
  flex-shrink: 0;
}

.md-list-text {
  font-size: 28rpx;
  color: #4a5568;
  line-height: 1.7;
  flex: 1;
}

.md-blockquote {
  background: #f7fafc;
  border-left: 6rpx solid #a0aec0;
  padding: 20rpx 24rpx;
  margin: 20rpx 0;
  border-radius: 0 12rpx 12rpx 0;
  font-size: 28rpx;
  color: #718096;
  font-style: italic;
}

.md-code-block {
  background: #1a1a2e;
  border-radius: 16rpx;
  margin: 20rpx 0;
  overflow: hidden;
}

.md-code-lang {
  display: block;
  background: #2d3748;
  color: #a0aec0;
  font-size: 22rpx;
  padding: 12rpx 24rpx;
}

.md-code-text {
  display: block;
  color: #68d391;
  font-size: 26rpx;
  padding: 24rpx;
  font-family: 'Menlo', 'Monaco', monospace;
  line-height: 1.6;
  word-break: break-all;
}

.md-alert {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  margin: 20rpx 0;
  border-radius: 16rpx;
}

.md-alert-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.md-alert-text {
  font-size: 28rpx;
  line-height: 1.7;
  flex: 1;
}

.md-success {
  background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
  border: 2rpx solid #28a745;
}

.md-success .md-alert-text {
  color: #155724;
}

.md-error {
  background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
  border: 2rpx solid #dc3545;
}

.md-error .md-alert-text {
  color: #721c24;
}

.md-warning {
  background: linear-gradient(135deg, #fff3cd 0%, #ffeeba 100%);
  border: 2rpx solid #ffc107;
}

.md-warning .md-alert-text {
  color: #856404;
}

.md-info {
  background: linear-gradient(135deg, #d1ecf1 0%, #bee5eb 100%);
  border: 2rpx solid #17a2b8;
}

.md-info .md-alert-text {
  color: #0c5460;
}

.md-table-container {
  margin: 20rpx 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.md-table {
  width: 100%;
  border-collapse: collapse;
  background: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.md-table-header {
  display: flex;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-bottom: 3rpx solid var(--primary-color);
}

.md-header-cell {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 20rpx 12rpx;
  min-height: 80rpx;
  font-weight: 700;
  color: var(--primary-dark);
  font-size: 26rpx;
  border-right: 1rpx solid rgba(245, 158, 11, 0.3);
}

.md-header-cell:last-child {
  border-right: none;
}

.md-table-row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #E8ECF0;
}

.md-table-row:last-child {
  border-bottom: none;
}

.md-table-row:nth-child(even) {
  background: #FAFBFC;
}

.md-table-cell {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 16rpx 12rpx;
  min-height: 80rpx;
  font-size: 24rpx;
  color: #4A5568;
  line-height: 1.6;
  word-break: break-all;
  border-right: 1rpx solid #E8ECF0;
}

.md-table-cell:last-child {
  border-right: none;
}

.md-table-cell text {
  vertical-align: middle;
}

.result-actions {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 24rpx 32rpx 32rpx;
  border-top: 2rpx solid #f0f0f0;
  margin-top: 32rpx;
}

.copy-btn,
.share-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none !important;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.copy-btn::after,
.share-btn::after {
  border: none !important;
}

.copy-btn {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #ffffff;
}

.copy-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 3rpx 10rpx rgba(16, 185, 129, 0.3);
}

.share-btn {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  color: #ffffff;
}

.share-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 3rpx 10rpx rgba(245, 158, 11, 0.3);
}

.action-icon {
  font-size: 32rpx;
}

.footer {
  padding: 60rpx 0 80rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #8E99A4;
  letter-spacing: 2rpx;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 998;
  transition: background 0.3s ease;
  pointer-events: none;
}

.picker-mask.show {
  background: rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

.picker-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  max-height: 70vh;
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.picker-popup.show {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  border-bottom: 2rpx solid #F0F4F8;
  position: relative;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A2E;
  flex: 1;
  text-align: center;
}

.popup-cancel,
.popup-confirm {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 600;
  padding: 8rpx 16rpx;
  min-width: 100rpx;
}

.popup-cancel {
  text-align: left;
}

.popup-confirm {
  text-align: right;
}

.popup-cancel:active,
.popup-confirm:active {
  opacity: 0.6;
}

.popup-options {
  max-height: 50vh;
  overflow-y: auto;
  padding: 16rpx 0;
}

.popup-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  transition: background 0.2s ease;
}

.popup-option:active {
  background: #F8FAFC;
}

.popup-option.selected {
  background: linear-gradient(90deg, rgba(245, 158, 11, 0.05) 0%, transparent 100%);
}

.option-main {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.option-logo-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: #F8FAFC;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  transition: all 0.3s ease;
}

.option-logo-wrapper.selected {
  box-shadow: 0 6rpx 20rpx rgba(245, 158, 11, 0.3);
  transform: scale(1.05);
}

.option-content {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
}

.option-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.option-desc {
  font-size: 24rpx;
  color: #8E99A4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.option-check-wrapper {
  margin-left: 20rpx;
  flex-shrink: 0;
}

.option-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #D0D7DE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
  transition: all 0.3s ease;
}

.option-check.selected {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-color: var(--primary-color);
  color: #ffffff;
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.4);
}

.popup-safe-area {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  background: #ffffff;
}

@media (max-width: 375px) {
  .section-title {
    font-size: 30rpx;
  }

  .section-subtitle {
    font-size: 22rpx;
  }

  .model-name {
    font-size: 26rpx;
  }

  .model-hint {
    font-size: 20rpx;
  }

  .submit-btn {
    height: 100rpx;
    font-size: 32rpx;
  }
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: rotate 0.8s linear infinite;
  margin-right: 16rpx;
}

/* Light neumorphism style: softer depth, cleaner hierarchy */
