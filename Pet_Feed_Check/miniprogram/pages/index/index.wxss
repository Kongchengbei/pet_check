/* Animal Crossing Theme Override */
.ac-theme {
  min-height: 100vh;
  color: #5c4638;
  font-family: "YouYuan", "幼圆", "STKaiti", "PingFang SC", "Microsoft YaHei", sans-serif;
}

page {
  background: #86c89d !important;
  --ac-cream: #f7f2e6;
  --ac-cream-deep: #efe5d1;
  --ac-brown: #6d4f3a;
  --ac-shadow: #b49f83;
  --ac-green: #5aa575;
  --ac-green-dark: #3e8962;
}

.ac-background {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  pointer-events: none;
  background: #86c89d;
}

.ac-leaf-pattern {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 2;
  opacity: 0.35;
  background-image:
    radial-gradient(circle at 18% 22%, rgba(96, 157, 114, 0.35) 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 74% 48%, rgba(96, 157, 114, 0.28) 0 7rpx, transparent 8rpx),
    radial-gradient(circle at 38% 76%, rgba(108, 169, 121, 0.33) 0 6rpx, transparent 7rpx),
    radial-gradient(circle at 89% 82%, rgba(96, 157, 114, 0.25) 0 6rpx, transparent 7rpx);
  background-size: 170rpx 170rpx, 200rpx 200rpx, 160rpx 160rpx, 190rpx 190rpx;
}

.ac-hill {
  position: absolute;
  left: -5%;
  right: -5%;
  z-index: 3;
  border-radius: 50% 50% 0 0;
}

.ac-hill-1 {
  bottom: -40rpx;
  height: 180rpx;
  background: rgba(125, 198, 179, 0.72);
}

.ac-hill-2 {
  bottom: -90rpx;
  height: 210rpx;
  background: rgba(71, 168, 140, 0.75);
}

.navbar-placeholder,
.container,
