    radial-gradient(34rpx 22rpx at 35% 40%, #fef8ed 99%, transparent 100%),
    radial-gradient(32rpx 20rpx at 58% 60%, #fef8ed 99%, transparent 100%),
    radial-gradient(30rpx 18rpx at 80% 45%, #fef8ed 99%, transparent 100%),
